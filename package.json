{
  "name": "signet-verify",
  "version": "0.4.0",
  "description": "Signet SDK — website age verification and cross-device Sign-in-with-Signet",
  "type": "module",
  "main": "./dist/signet-verify.js",
  "types": "./dist/signet-verify.d.ts",
  "exports": {
    ".": {
      "types": "./dist/signet-verify.d.ts",
      "import": "./dist/signet-verify.js",
      "default": "./dist/signet-verify.js"
    },
    "./iife": "./dist/signet-verify.iife.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "provenance": true
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && tsc && npm run build:iife",
    "build:iife": "esbuild src/signet-verify.ts --bundle --format=iife --global-name=Signet --outfile=dist/signet-verify.iife.js --minify --target=es2020",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@noble/curves": "^1.8.1",
    "@noble/hashes": "^1.7.1",
    "nostr-tools": "^2.23.3"
  },
  "devDependencies": {
    "esbuild": "^0.28.0",
    "signet-protocol": "^1.6.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/forgesworn/signet-verify.git"
  }
}
