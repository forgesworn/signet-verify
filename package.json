{
  "name": "signet-verify",
  "version": "0.1.0",
  "description": "Add Signet age verification to any website — one script tag, one function call",
  "type": "module",
  "main": "./dist/signet-verify.js",
  "types": "./dist/signet-verify.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "esbuild src/signet-verify.ts --bundle --format=iife --global-name=Signet --outfile=dist/signet-verify.js --minify --target=es2020",
    "build:esm": "esbuild src/signet-verify.ts --bundle --format=esm --outfile=dist/signet-verify.esm.js --minify --target=es2020",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@noble/curves": "^1.8.1",
    "@noble/hashes": "^1.7.1",
    "nostr-tools": "^2.23.3"
  },
  "devDependencies": {
    "esbuild": "^0.25.12",
    "signet-protocol": "file:../signet",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/forgesworn/signet-verify.git"
  }
}
